# Environment variables for the Modular Web Platform
# The variables defined here are used in the installation and configuration scripts.
# The information is public and can be shared freely, including on GitHub.

# URLs of the GitHub repositories for the frontend and backend and their respective directories
FRONTEND_GITHUB_URL=https://github.com/hz-andkorrel/modulair-web-platform
BACKEND_GITHUB_URL=https://github.com/hz-andkorrel/modulair-achterkantje
FRONTEND_CURRENT_BRANCH=feature/dashboard
BACKEND_CURRENT_BRANCH=dockerize
FRONTEND_DIR=frontend
BACKEND_DIR=backend

# Names for the Docker 
FRONTEND_IMAGE_NAME=m-frontend-image
BACKEND_IMAGE_NAME=m-backend-image
FRONTEND_CONTAINER_NAME=m-frontend-container
BACKEND_CONTAINER_NAME=m-backend-container
FRONTEND_DOCKERFILE_NAME=Dockerfile.dev
BACKEND_DOCKERFILE_NAME=Dockerfile

# List with all the required packages for the installation
REQUIRED_PACKAGES=(git docker docker-compose)

# Port settings
FRONTEND_CONTAINER_PORT=4200
FRONTEND_HOST_PORT=80