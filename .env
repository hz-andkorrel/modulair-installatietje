# Environment variables for the Modular Web Platform
# The variables defined here are used in the installation and configuration scripts.
# The information is public and can be shared freely, including on GitHub.

# URLs of the GitHub repositories for the frontend and backend
FRONTEND_GITHUB_URL=https://github.com/hz-andkorrel/modulair-web-platform
BACKEND_GITHUB_URL=https://github.com/hz-andkorrel/modulair-achterkantje

# Directory names for the cloned repositories
FRONTEND_DIR=frontend
BACKEND_DIR=backend